			<CheckBoxType>Auto</CheckBoxType>
			<ContextMenu name="УдалятьКаталогСРепозиториемПослеТестаКонтекстноеМеню" id="16"/>
			<ExtendedTooltip name="УдалятьКаталогСРепозиториемПослеТестаРасширеннаяПодсказка" id="17"/>
		</CheckBoxField>
